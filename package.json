{
  "name": "symposium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "action:check": "tsx scripts/actionLedgerCheck.ts",
    "action-state:check": "tsx scripts/actionStateGuardCheck.ts",
    "api-client:check": "tsx scripts/apiClientCheck.ts",
    "architecture:check": "tsx scripts/architectureBoundaryCheck.ts",
    "attachment:check": "tsx scripts/attachmentSecurityCheck.ts",
    "dev": "WATCHPACK_POLLING=true next dev --webpack",
    "api:dev": "tsx watch apps/api/src/server.ts",
    "api:preflight": "tsx apps/api/src/config/preflight.ts",
    "api:smoke": "tsx apps/api/src/smoke.ts",
    "api:smoke:writes": "tsx apps/api/src/smokeWrites.ts",
    "api:start": "tsx apps/api/src/server.ts",
    "api:typecheck": "tsc --noEmit -p tsconfig.api.json",
    "build": "next build",
    "core:check": "tsx scripts/symposiumCoreCheck.ts",
    "cross-tab:check": "tsx scripts/crossTabItemSyncCheck.ts",
    "comment-attachment:check": "tsx scripts/commentAttachmentCheck.ts",
    "entities:check": "tsx scripts/entityStoreCheck.ts",
    "entity-revision:check": "tsx scripts/entityRevisionCheck.ts",
    "follow-reconciliation:check": "tsx scripts/followReconciliationCheck.ts",
    "infrastructure:check": "tsx scripts/infrastructureBoundaryCheck.ts",
    "identity:check": "tsx scripts/identitySelectionCheck.ts",
    "item-mutation:check": "tsx scripts/itemMutationGuardCheck.ts",
    "live-transport:check": "tsx scripts/liveTransportCheck.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx apps/api/src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "live:env:report": "tsx scripts/liveEnvReport.ts",
    "live:env:check": "tsx scripts/liveEnvReport.ts --strict",
    "mutation:check": "tsx scripts/mutationEnvelopeCheck.ts",
    "note-revision:check": "tsx scripts/noteRevisionCheck.ts",
    "profile:check": "tsx scripts/profileActivityCheck.ts",
    "post-publishing:check": "tsx scripts/postAttachmentPublishingCheck.ts",
    "entry-session:check": "tsx scripts/browserSessionEntryCheck.ts",
    "platform:check": "tsx scripts/platformKernelCheck.ts",
    "reconciliation:check": "tsx scripts/inquiryReconciliationCheck.ts",
    "routing:check": "tsx scripts/canonicalRouteCheck.ts",
    "security:check": "tsx scripts/securityBoundaryCheck.ts",
    "styles:check": "tsx scripts/styleLayerCheck.ts",
    "storage-deletion:check": "tsx scripts/storageDeletionCheck.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:all": "npm run typecheck && npm run api:typecheck",
    "deploy:api:check": "npm run api:preflight && npm run api:typecheck",
    "verify": "npm run architecture:check && npm run platform:check && npm run styles:check && npm run security:check && npm run infrastructure:check && npm run routing:check && npm run entities:check && npm run entity-revision:check && npm run follow-reconciliation:check && npm run api-client:check && npm run live-transport:check && npm run core:check && npm run action:check && npm run action-state:check && npm run reconciliation:check && npm run identity:check && npm run item-mutation:check && npm run cross-tab:check && npm run attachment:check && npm run comment-attachment:check && npm run storage-deletion:check && npm run mutation:check && npm run note-revision:check && npm run profile:check && npm run post-publishing:check && npm run entry-session:check && npm run typecheck:all && npm run build"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1075.0",
    "@aws-sdk/s3-request-presigner": "3.1075.0",
    "@clerk/backend": "3.8.4",
    "@clerk/nextjs": "7.5.9",
    "@fastify/cors": "11.2.0",
    "@trpc/server": "11.18.0",
    "@upstash/redis": "1.38.0",
    "docx-preview": "^0.4.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "fastify": "5.9.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "4.8.3",
    "tsx": "4.22.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
